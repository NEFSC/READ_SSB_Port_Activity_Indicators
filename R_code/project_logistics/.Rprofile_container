# Reading in requires a wrapper to wait until startup is done.
setHook("rstudio.sessionInit", function(newSession) {
  library(keyring)
  kb <<- keyring::backend_file$new()
  kb$keyring_unlock("my_keyring")
  
  id   <<- kb$get(service = "my_oracle_userid", keyring = "my_keyring")
  mypass <<- kb$get(service = "my_oracle_pw_at_NEFSC", keyring = "my_keyring")
  tns_alias <<- kb$get(service = "my_tnsalias", keyring = "my_keyring")

  nefscdb_con <<- quote(dbConnect(drv, username = id, password = mypass, dbname = tns_alias))
  message("Oracle creds loaded from Keyring.")
  message("Establish and oracle connection with myconnection<-eval(nefscdb_con)")
  
  
  
  my_census_api_key <<- kb$get(service = "my_census_api_key", keyring = "my_keyring")

  Sys.setenv(CENSUS_API_KEY=my_census_api_key)

  message("CENSUS key set to: ", Sys.getenv("CENSUS_API_KEY"))
  
#cleanup
  rm(kb, envir = .GlobalEnv)
  
}, action = "append")

