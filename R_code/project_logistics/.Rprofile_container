##########################################################
# Create and Load things into the keyring called "my_keyring". Run this interactively.
##########################################################
library("keyring")
kb <- keyring::backend_file$new()
# Create a named keyring (prompts for a keyring password interactively)
# this get's put in .config/r-keyring/my_keyring

kb$keyring_create("my_keyring")

# store the object  "my_oracle_userid". Perhaps you would store your userid here?
kb$set(service ="my_oracle_userid", keyring = "my_keyring")

# store the object  "my_oracle_pw_at_NEFSC". Perhaps you would store your password here?
 kb$set(service ="my_oracle_pw_at_NEFSC", keyring = "my_keyring")
 kb$set(service ="my_tnsalias", keyring = "my_keyring")

kb$set(service ="my_census_api_key", keyring = "my_keyring")
kb$set(service ="github_token", keyring = "my_keyring")


